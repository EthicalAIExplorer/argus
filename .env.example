# Timezone used for date boundaries and digest timestamps
ARGUS_TIMEZONE=UTC

# IMAP ingest (Gmail inbound)
ARGUS_IMAP_HOST=imap.gmail.com
ARGUS_IMAP_USER=argusnewswire@gmail.com
ARGUS_IMAP_PASSWORD=your_imap_app_password
ARGUS_IMAP_FOLDER=INBOX

# SMTP delivery (Gmail outbound)
ARGUS_SMTP_HOST=smtp.gmail.com
ARGUS_SMTP_PORT=587
ARGUS_SMTP_USE_SSL=0
ARGUS_SMTP_USER=argusnewswire@gmail.com
ARGUS_SMTP_PASSWORD=your_smtp_app_password
ARGUS_SMTP_FROM=argusnewswire@gmail.com

# Comma-separated digest recipients
ARGUS_DIGEST_RECIPIENTS=argusnewswire@gmail.com

# MCP auth token for local/tunneled server
ARGUS_AUTH_TOKEN=change-me-long-random-string
